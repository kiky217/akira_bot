# Indodax
INDODAX_API_KEY=ISI_DENGAN_API_KEY
INDODAX_API_SECRET=ISI_DENGAN_API_SECRET
INDODAX_BASE_URL=https://indodax.com/api

# Trading pairs
PAIRS=BTC_IDR,ETH_IDR,XRP_IDR

# Mode trading
ENABLE_LIVE_TRADING=false
DRY_RUN=true
ORDER_MODE=AUTO

# Risk management
MAX_NOTIONAL_IDR=1000000
MAX_ORDER_PER_PAIR=1
MAX_DAILY_LOSS_IDR=50000
TAKE_PROFIT_PERCENT=0.5
STOP_LOSS_PERCENT=0.3
TRAILING_STOP_PERCENT=0.2
SLIPPAGE_TOLERANCE_PERCENT=0.15

# Scalping behavior
POLL_INTERVAL_SEC=1
MIN_SPREAD_PERCENT=0.1
MIN_VOLUME_IDR=10000000
COOLDOWN_AFTER_TRADE_SEC=30

# Telegram notification
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=ISI_TOKEN_TELEGRAM
TELEGRAM_CHAT_ID=ISI_CHAT_ID

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/trading.log
